{
  "nodeModulesDir": "auto",
  "imports": {
    "@eslint/js": "npm:@eslint/js@^10.0.1",
    "eslint": "npm:eslint@^10.5.0",
    "eslint-plugin-react-hooks": "npm:eslint-plugin-react-hooks@^7.1.1",
    "globals": "npm:globals@^17.7.0",
    "ichor": "../ichor/pkg/ichor.js",
    "react": "npm:react@^19.2.8",
    "react/": "npm:react@^19.2.8/",
    "react-dom": "npm:react-dom@^19.2.7",
    "react-dom/client": "npm:react-dom@^19.2.7/client",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "typescript-eslint": "npm:typescript-eslint@^8.62.1"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "npm:@types/react@^19.2.14"
  },
  "fmt": {
    "exclude": ["**/*.svg"]
  },
  "lint": {
    "rules": {
      "exclude": []
    }
  },
  "tasks": {
    "serve": "deno run --allow-net --allow-read jsr:@std/http/file-server public/",
    "clean": "rm -rf public/dist/* 2>/dev/null",
    "vendor-wasm": "mkdir -p public/dist && cp ../ichor/pkg/* public/dist/",
    "build": "deno task clean; deno task vendor-wasm && deno check && deno run --allow-env --allow-run npm:esbuild src/main.tsx --bundle --minify --jsx=automatic --format=esm --outdir=public/dist --out-extension:.js=.js",
    "lint": "deno lint && deno run --allow-read --allow-env npm:eslint .",
    "test": "deno test --allow-env=NODE_ENV"
  },
  "dependencies": {
    "@eslint/js": "npm:@eslint/js@^10.0.1",
    "@types/react": "npm:@types/react@^19.2.14",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "esbuild": "npm:esbuild@^0.25.0",
    "eslint": "npm:eslint@^10.2.1",
    "eslint-plugin-react-hooks": "npm:eslint-plugin-react-hooks@^7.1.1",
    "globals": "npm:globals@^17.5.0",
    "react": "npm:react@^19.2.5",
    "react-dom": "npm:react-dom@^19.2.5",
    "typescript": "npm:typescript@~6.0.2",
    "typescript-eslint": "npm:typescript-eslint@^8.58.2"
  }
}
