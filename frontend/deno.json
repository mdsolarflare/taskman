{
    "nodeModulesDir": "auto",
    "imports": {
        "ichor": "../ichor/pkg/ichor.js",
        "react": "npm:react@^19.2.5",
        "react/": "npm:react@^19.2.5/",
        "react-dom": "npm:react-dom@^19.2.5",
        "react-dom/client": "npm:react-dom@^19.2.5/client",
        "@std/assert": "jsr:@std/assert@^1.0.16"
    },
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "deno.ns"],
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "jsxImportSourceTypes": "npm:@types/react@^19.2.14"
    },
    "fmt": {
        "exclude": ["**/*.svg"]
    },
    "lint": {
        "rules": {
            "exclude": []
        }
    },
    "tasks": {
        "dev": "deno run -A node_modules/.bin/vite --host",
        "build": "deno check && deno run -A node_modules/.bin/vite build",
        "lint": "deno run -A node_modules/.bin/eslint .",
        "preview": "deno run -A node_modules/.bin/vite preview",
        "test": "deno test --allow-env"
    },
    "dependencies": {
        "@eslint/js": "npm:@eslint/js@^10.0.1",
        "@types/react": "npm:@types/react@^19.2.14",
        "@types/react-dom": "npm:@types/react-dom@^19.2.3",
        "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^6.0.1",
        "eslint": "npm:eslint@^10.2.1",
        "eslint-plugin-react-hooks": "npm:eslint-plugin-react-hooks@^7.1.1",
        "eslint-plugin-react-refresh": "npm:eslint-plugin-react-refresh@^0.5.2",
        "globals": "npm:globals@^17.5.0",
        "react": "npm:react@^19.2.5",
        "react-dom": "npm:react-dom@^19.2.5",
        "typescript": "npm:typescript@~6.0.2",
        "typescript-eslint": "npm:typescript-eslint@^8.58.2",
        "vite": "npm:vite@^8.0.10"
    }
}
